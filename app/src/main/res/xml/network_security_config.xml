<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Hermes gateways are typically reached over plain HTTP on a trusted LAN
         (http://<host-ip>:8642) or the emulator host. Cleartext is therefore
         permitted by default; use an HTTPS reverse proxy for anything beyond a
         trusted local network (see README security notes). -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
