{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Material Design 3 dark-mode-first mobile workbench for floating Hermes agent bubbles.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.545,
          0.514,
          1
        ],
        "hex": "#8b83ff"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.447,
          0.722,
          1
        ],
        "hex": "#72b8ff"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.478,
          0.102
        ],
        "hex": "#ff7a1a"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.027,
          0.031,
          0.043
        ],
        "hex": "#07080b"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.063,
          0.067,
          0.086
        ],
        "hex": "#101116"
      }
    },
    "surfaceRaised": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.133,
          0.145,
          0.176
        ],
        "hex": "#22252d"
      }
    },
    "surfaceMuted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.094,
          0.102,
          0.125
        ],
        "hex": "#181a20"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.204,
          0.22,
          0.267
        ],
        "hex": "#343844"
      }
    },
    "active": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.404,
          0.357,
          0.91
        ],
        "hex": "#675be8"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.271,
          0.831,
          0.514
        ],
        "hex": "#45d483"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.784,
          0.341
        ],
        "hex": "#ffc857"
      }
    },
    "info": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.447,
          0.722,
          1
        ],
        "hex": "#72b8ff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 28,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.75,
          "unit": "rem"
        },
        "fontWeight": 650,
        "letterSpacing": {
          "value": -0.025,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.125,
          "unit": "rem"
        },
        "fontWeight": 650,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 450
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 650
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    }
  }
}
