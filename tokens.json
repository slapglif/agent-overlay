{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Replit Agent inspired mobile workbench for floating Hermes agent bubbles.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.122,
          0.137,
          0.157
        ],
        "hex": "#1f2328"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.373,
          0.388,
          0.408
        ],
        "hex": "#5f6368"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.384,
          0.027
        ],
        "hex": "#f26207"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.953,
          0.949,
          0.929
        ],
        "hex": "#f3f2ed"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.976,
          0.957
        ],
        "hex": "#faf9f4"
      }
    },
    "surfaceRaised": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surfaceMuted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.929,
          0.922,
          0.89
        ],
        "hex": "#edebe3"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.847,
          0.839,
          0.8
        ],
        "hex": "#d8d6cc"
      }
    },
    "active": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.424,
          0.361,
          0.906
        ],
        "hex": "#6c5ce7"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.176,
          0.643,
          0.306
        ],
        "hex": "#2da44e"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.718,
          0.475,
          0.122
        ],
        "hex": "#b7791f"
      }
    },
    "info": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.231,
          0.51,
          0.965
        ],
        "hex": "#3b82f6"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 28,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.75,
          "unit": "rem"
        },
        "fontWeight": 650,
        "letterSpacing": {
          "value": -0.035,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.125,
          "unit": "rem"
        },
        "fontWeight": 650,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 450
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 650
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    }
  }
}
